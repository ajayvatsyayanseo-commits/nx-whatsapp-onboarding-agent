{
  "name": "nxtutors/whatsapp-onboarding-agent",
  "description": "Production-ready WhatsApp signup and onboarding agent for NXtutors.",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/queue": "^10.0|^11.0|^12.0",
    "illuminate/cache": "^10.0|^11.0|^12.0",
    "illuminate/validation": "^10.0|^11.0|^12.0",
    "illuminate/filesystem": "^10.0|^11.0|^12.0",
    "guzzlehttp/guzzle": "^7.8"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.5|^11.0"
  },
  "autoload": {
    "psr-4": {
      "NxTutors\\WhatsAppOnboarding\\": "src/",
      "NxTutors\\WhatsAppOnboarding\\Database\\": "database/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NxTutors\\WhatsAppOnboarding\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "NxTutors\\WhatsAppOnboarding\\Bootstrap\\ServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "php -l src/Bootstrap/ServiceProvider.php"
  },
  "config": {
    "sort-packages": true
  }
}
